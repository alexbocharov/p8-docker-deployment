# --- Core Deployment Settings ---
# This must match the name used in your 'docker-compose up' command
DEPLOYMENT_NAME=inst1

# --- Database Connection (Parus 8 Web) ---
# Replace host, port, service name, user, and password with your actual Oracle DB details
AuthSettings__Connections__0__name=INST1DB
AuthSettings__Connections__0__kind=oracle
AuthSettings__Connections__0__connectionString=direct=true;host=172.20.10.140;port=1521;service name=INST1DB;user id=parus_web;password=YourPassword;pooling=true;max pool size=100;min pool size=1;Unicode=true

# --- PARUS_RPT user connection for Report Service ---
ParusRpt__Connection__Kind=oracle
ParusRpt__Connection__ConnectionString=direct=true;host=172.20.10.140;port=1521;service name=INST1DB;user=PARUS_RPT;password=ReportPassword;pooling=false;max pool size=1;min pool size=1;Run Once Command=ALTER SESSION SET CURRENT_SCHEMA = PARUS
ParusRpt__Connection__DbMonitorEnabled=false

# --- PARUS_SRV user connection for Report Service (if different from PARUS_RPT) ---
ParusSrv__Connection__Kind=oracle
ParusSrv__Connection__ConnectionString=direct=true;host=172.20.10.140;port=1521;service name=INST1DB;user=PARUS_SRV;password=ServicePassword;pooling=false;max pool size=1;min pool size=1;Run Once Command=ALTER SESSION SET CURRENT_SCHEMA = PARUS
ParusSrv__Connection__DbMonitorEnabled=false

# --- Parus 8 Applications (Modules) ---
# Module 0: Administrator
AuthSettings__Applications__0__code=Admin
AuthSettings__Applications__0__name=Administrator

# Module 1: Designer
AuthSettings__Applications__1__code=Designer
AuthSettings__Applications__1__name=Extension Designer

# Module 2: Accounting
AuthSettings__Applications__2__code=BudgAcnt
AuthSettings__Applications__2__name=Budget Accounting

# --- Company Settings ---
AuthSettings__Companies__0__code=ORG001
AuthSettings__Companies__0__name=Main Organization Unit

# --- Application Behavior ---
ASPNETCORE_ENVIRONMENT=Production
# These are handled by docker-compose.yml but can be overridden here if needed:
# Hosting__UsePathBase=true
# Hosting__PathBase=/inst1
